    given-names: Dominik
    email: dominik@qreativelab.io
    affiliation: QreativeLab Inc.
repository-code: "https://github.com/dom-omg/cobalt-sentinel"
license: Apache-2.0
version: "1.0.0"
date-released: "2026-04-28"
keywords:
  - AI safety
  - behavioral drift detection
  - autonomous agents
  - sequential testing
  - SPRT
  - cosine distance
  - identity drift
preferred-citation:
  type: article
  title: "Identity Drift Detection in Autonomous AI Agents via Cosine Behavioral Distance"
  authors:
    - family-names: Blain
      given-names: Dominik
      email: dominik@qreativelab.io
      affiliation: QreativeLab Inc.
  year: 2026
  journal: arXiv preprint cs.AI
  notes: >
    SS-CBD achieves 2.61x mean detection-time speedup over LRT on N=500 trials,
    3/4 drift scenarios (peak 5.05x financial_gradual). Case study (make exp7):
    100% detection of slow-burn KB-poison attack at median 9 min, CBD fails 62%.
    Reproducible via make exp1 seed=42; make exp7 seed=42.
  url: "https://github.com/dom-omg/cobalt-ai/blob/main/papers/identity_drift.md"
